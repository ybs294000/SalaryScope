        "\\bmaster of science\\b",
        "\\bmsc\\b",
        "\\bm\\.sc\\b",
        "\\bm\\.s\\b",
        "\\bm\\.e\\b",
        "\\bme\\b",
        "\\bmba\\b",
        "\\bmaster(?:'s)?\\b",
        "\\bmasters\\b",
        "\\bpostgraduate\\b",
        "\\bpg diploma\\b",
        "\\bpgdip\\b",

        "\\bmasterarbeit\\b",
        "\\bmagister\\b",
        "\\bdiplom\\b",

        "\\bmast\\u00e8re\\b",
        "\\bmaster\\s+recherche\\b",

        "\\bm\\u00e1ster\\b",
