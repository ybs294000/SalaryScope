{
  "_comment": "Education level lexicon. Each level key maps to a list of regex patterns (applied with re.search, case-insensitive). Levels are checked from highest (3) to lowest (0) and the first match wins. Add new patterns freely.",
  "_version": "1.1",
  "_languages": "English, German (de), French (fr), Spanish (es), Portuguese (pt)",

  "levels": {
