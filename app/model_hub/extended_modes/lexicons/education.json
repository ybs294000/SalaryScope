        "\\bb\\.e\\b",
        "\\bbe\\b",
        "\\bb\\.sc\\b",
        "\\bbsc\\b",
        "\\bbca\\b",
        "\\bbachelor(?:'s)?\\b",
        "\\bundergraduate\\b",
        "\\bb\\.a\\b",
        "\\bba\\b",
        "\\bb\\.com\\b",
